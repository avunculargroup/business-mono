{
  "name": "platform",
  "private": true,
  "scripts": {
    "dev:agents": "turbo run dev --filter=@platform/agents",
    "dev:web": "turbo run dev --filter=@platform/web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate-types": "pnpm --filter @platform/db generate-types",
    "db:migrate": "pnpm --filter @platform/db db:migrate",
    "db:diff": "pnpm --filter @platform/db db:diff",
    "db:pull": "pnpm --filter @platform/db db:pull",
    "db:reset": "pnpm --filter @platform/db db:reset"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.5"
  },
  "packageManager": "pnpm@9.15.0"
}
