# Supabase — required for all environments
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter — optional. Read server-side only (never exposed to the browser) to
# show the credits balance on the dashboard. The OpenRouterCredits card degrades
# to "Credits unavailable" when unset. Use a dedicated key so it can be revoked
# independently of the agent server's key.
OPENROUTER_API_KEY=your-openrouter-key
