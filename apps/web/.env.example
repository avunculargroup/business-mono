# Supabase — required for all environments
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Agents server — required for Simon web integration
# Railway internal URL in production: http://agents.railway.internal:3000
# Local development: http://localhost:3000
AGENTS_URL=http://localhost:3000
AGENTS_API_KEY=your-shared-secret
