# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id
# Postgres connection string for Mastra's internal thread/memory storage (PostgresStore).
# This is NOT the Supabase JS client — that uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (HTTPS).
#
# Recommended (no IPv6 issues): add a Railway Postgres plugin to your project, then set:
# MASTRA_DB_URL=${{Postgres.DATABASE_URL}}
# Railway-internal Postgres is always IPv4 and on the private network.
#
# Alternative: Supabase direct connection (db.[ref].supabase.co:5432) — only works if the
# Supabase IPv4 Add-On is enabled (Dashboard → Settings → Add-Ons → IPv4 address, ~$4/mo).
# Without it, newer Supabase projects resolve to IPv6 only, which Railway cannot reach.
#
# SUPABASE_DB_URL is accepted as a fallback if MASTRA_DB_URL is not set.
MASTRA_DB_URL=postgresql://postgres:password@postgres.railway.internal:5432/railway

# AI provider — choose ONE of the following:

# Option 1: Anthropic (direct) — default
ANTHROPIC_API_KEY=sk-ant-...
# Override model (optional, default: anthropic/claude-sonnet-4-5)
# ANTHROPIC_MODEL=anthropic/claude-sonnet-4-5

# Option 2: OpenRouter (access any model via a single API key)
# OPENROUTER_API_KEY=sk-or-v1-...
# To use Claude via OpenRouter:
#   OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
# To use another model via OpenRouter (e.g. GPT-4o):
#   ANTHROPIC_MODEL=openai/gpt-4o-mini
# (Do not set ANTHROPIC_MODEL for Claude models; use OPENROUTER_MODEL instead)

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...

# Deepgram (transcription)
DEEPGRAM_API_KEY=...

# Telnyx (phone recordings)
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Zoom (video recordings)
ZOOM_WEBHOOK_SECRET_TOKEN=...

# Researcher (web search and crawling)
TAVILY_API_KEY=tvly-...
FIRECRAWL_API_KEY=fc-...

# Signal CLI (sidecar on Railway private network)
SIGNAL_CLI_API_URL=http://signal-cli.railway.internal:8080
SIGNAL_CLI_NUMBER=+61400000000
# For local development, override with: SIGNAL_CLI_API_URL=http://localhost:8080
# Kill switch for the Signal listener — set to "false" to skip subscribing on
# boot (useful when running locally without a registered Signal number).
# SIGNAL_LISTENER_ENABLED=true

# Mastra Cloud observability (optional) — when set, the CloudExporter ships
# traces to https://observability.mastra.ai alongside the local
# DefaultExporter. The CloudExporter self-disables if this is unset, so the
# variable is only needed in production.
# MASTRA_CLOUD_ACCESS_TOKEN=...
# Optional project-scoping for Mastra Cloud (otherwise endpoint-derived):
# MASTRA_PROJECT_ID=...

# Railway (set automatically in production)
PORT=3000
RAILWAY_PUBLIC_DOMAIN=your-service.railway.app
