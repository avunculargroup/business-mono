{
  "name": "@platform/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./dist/server.js"
    },
    "./browser": {
      "types": "./src/browser.ts",
      "import": "./dist/browser.js"
    },
    "./types": {
      "types": "./src/types/database.ts",
      "import": "./dist/types/database.js"
    }
  },
  "main": "dist/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "generate-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/database.ts",
    "seed:brand-voice": "tsx src/seeds/brand-voice.ts"
  },
  "dependencies": {
    "@platform/shared": "workspace:*",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5"
  }
}
